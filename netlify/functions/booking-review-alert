// Netlify Function: recibe webhooks de changedetection.io cuando detecta
// un cambio en el contador de reseñas / puntuación de Booking.com,
// y guarda un aviso en Supabase para que el tablón lo muestre como push-up.

const SUPA_URL = "https://fdszxvscbfgyoinylbfu.supabase.co";
const SUPA_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZkc3p4dnNjYmZneW9pbnlsYmZ1Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA5OTM4MTcsImV4cCI6MjA5NjU2OTgxN30.6ZdkoJr_ANqFpiciXwJ2eJ7QfpCvKBwK0ztrkydvEFM";

// Nombres bonitos para cada establecimiento, según el watch_id/tag que le pongas en changedetection.io
const ESTABLISHMENT_NAMES = {
  boreal: "Hotel Boreal",
  condor: "Hotel Cóndor",
  apartamentos_condor: "Apartamentos Cóndor",
  magaluf_beach: "Magaluf Beach",
  magaluf_apartments: "Magaluf Apartamentos",
  santa_ponsa: "Santa Ponça Pins",
  claudia: "Claudia by Nura",
};

exports.handler = async function (event) {
  if (event.httpMethod !== "POST") {
    return { statusCode: 405, body: "Method Not Allowed" };
  }

  try {
    const body = JSON.parse(event.body || "{}");

    // changedetection.io envía el contenido actual de la página (o el fragmento vigilado) en body.current_snapshot,
    // y normalmente el watch_id o un título personalizado en body.watch_uuid / body.watch_title.
    // Adaptamos de forma flexible a varios formatos posibles del payload.
    const establishmentKey = (body.establishment || body.tag || body.watch_title || "").toLowerCase().replace(/\s+/g, "_");
    const establishmentName = ESTABLISHMENT_NAMES[establishmentKey] || body.watch_title || "Alojamiento";

    const snapshot = body.current_snapshot || body.text || "";

    // Intentamos extraer una puntuación tipo "9,2" o "9.2" del snapshot
    const scoreMatch = snapshot.match(/(\d{1,2}[.,]\d)\s*(?:\/\s*10)?/);
    const score = scoreMatch ? scoreMatch[1].replace(",", ".") : null;

    // Intentamos extraer el número de reseñas, ej "1.841 comentarios" o "1841 reviews"
    const countMatch = snapshot.match(/([\d.,]{3,})\s*(?:comentarios|reseñas|reviews)/i);
    const reviewCount = countMatch ? countMatch[1] : null;

    const payload = {
      establecimiento: establishmentName,
      puntuacion: score,
      num_resenas: reviewCount,
      visto: false,
      created_at: new Date().toISOString(),
    };

    const r = await fetch(SUPA_URL + "/rest/v1/resenas_avisos", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        apikey: SUPA_KEY,
        Authorization: "Bearer " + SUPA_KEY,
        Prefer: "return=minimal",
      },
      body: JSON.stringify(payload),
    });

    if (!r.ok) {
      const errText = await r.text();
      return { statusCode: 500, body: JSON.stringify({ error: errText }) };
    }

    return {
      statusCode: 200,
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ ok: true, saved: payload }),
    };
  } catch (err) {
    return { statusCode: 500, body: JSON.stringify({ error: err.message }) };
  }
};
